# ──────────────────────────────────────────────────────────────
# Stratégie des fichiers env
#
#   .env.example   → ce fichier, template, jamais commité avec des secrets
#   .env           → variables Docker Compose (POSTGRES_PASSWORD, secrets prod)
#   .env.local     → overrides Next.js pour dev local (hostnames localhost)
#
# Pour démarrer en dev :
#   cp .env.example .env          → ajuster POSTGRES_PASSWORD
#   Créer .env.local manuellement → DATABASE_URL et MINIO_ENDPOINT sur localhost
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TropChaud

# ──────────────────────────────────────────────
# Base de données PostgreSQL
# Hostnames Docker Compose (réseau interne) — utiliser localhost dans .env.local
# ──────────────────────────────────────────────
POSTGRES_PASSWORD=changez-ce-mot-de-passe
DATABASE_URL=postgresql://tropchaud:${POSTGRES_PASSWORD}@postgres:5432/tropchaud

# ──────────────────────────────────────────────
# Authentification (NextAuth / Auth.js v5)
# Générer avec : openssl rand -base64 32
# ──────────────────────────────────────────────
AUTH_SECRET=remplacez-par-une-chaine-aleatoire-de-32-caracteres

# ──────────────────────────────────────────────
# MinIO (stockage fichiers compatible S3)
# Hostnames Docker Compose (réseau interne) — utiliser localhost dans .env.local
# ──────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=changez-cet-access-key
MINIO_SECRET_KEY=changez-ce-secret-key
MINIO_BUCKET=tropchaud
MINIO_USE_SSL=false
