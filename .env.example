# ──────────────────────────────────────────────────────────────
# Stratégie des fichiers env
#
#   .env.example        → ce fichier, template, jamais commité avec des secrets
#   .env                → variables de dev local (cp .env.example .env)
#   .env.local          → overrides Next.js uniquement (MINIO_ENDPOINT/PORT pour dev)
#   compose.override.yml → expose le port Postgres 5433 sur le host (dev uniquement)
#
# Pour démarrer en dev :
#   cp .env.example .env          → ajuster POSTGRES_PASSWORD, AUTH_SECRET, etc.
#   Créer .env.local manuellement → MINIO_ENDPOINT=localhost et MINIO_PORT=9010
#   docker compose up -d postgres minio createbuckets  → compose.override.yml appliqué auto
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TropChaud

# ──────────────────────────────────────────────
# Base de données PostgreSQL
# En dev, Postgres est accessible sur localhost:5433 via compose.override.yml
# ──────────────────────────────────────────────
POSTGRES_PASSWORD=changez-ce-mot-de-passe
DATABASE_URL=postgresql://tropchaud:changez-ce-mot-de-passe@localhost:5433/tropchaud

# ──────────────────────────────────────────────
# Authentification (Auth.js v5)
# Générer avec : openssl rand -base64 32
# ──────────────────────────────────────────────
AUTH_SECRET=remplacez-par-une-chaine-aleatoire-de-32-caracteres
# URL publique de l'app — requis en production derrière un reverse proxy
# Laisser vide en dev local (auto-détecté)
AUTH_URL=

# ──────────────────────────────────────────────
# Compte admin (créé automatiquement au démarrage par le service seeder)
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@exemple.fr
ADMIN_PASSWORD=changez-ce-mot-de-passe

# ──────────────────────────────────────────────
# MinIO (stockage fichiers compatible S3)
# Ces valeurs sont utilisées par Docker Compose (hostname interne "minio")
# → créer .env.local avec MINIO_ENDPOINT=localhost et MINIO_PORT=9010 pour le dev server Next.js
# ──────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=changez-cet-access-key
MINIO_SECRET_KEY=changez-ce-secret-key
MINIO_BUCKET=tropchaud
MINIO_USE_SSL=false
# URL publique de MinIO pour les URLs pré-signées (hostname résolvable par le navigateur)
# Laisser vide en dev local (utilise MINIO_ENDPOINT par défaut)
MINIO_PUBLIC_URL=
